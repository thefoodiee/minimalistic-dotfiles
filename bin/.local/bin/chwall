#!/usr/bin/env bash
# chwall - change wallpaper + generate colors using matugen
# Usage: chwall /path/to/image.jpg

set -euo pipefail

progname="$(basename "$0")"

usage() {
  cat <<EOF
Usage: $progname IMAGE

Change wallpaper, regenerate colors using matugen,
and generate a tinted hyprlock image.

Example:
  $progname ~/Pictures/wall.jpg
EOF
  exit 1
}

[[ $# -ne 1 ]] && usage

IMAGE="$1"

if ! IMAGE_PATH="$(realpath -- "$IMAGE" 2>/dev/null)"; then
  echo "Error: cannot resolve path '$IMAGE'." >&2
  exit 2
fi

[[ -f "$IMAGE_PATH" ]] || {
  echo "Error: file not found: $IMAGE_PATH" >&2
  exit 3
}

command -v matugen >/dev/null || {
  echo "Error: 'matugen' not found."
  exit 4
}

command -v magick >/dev/null || {
  echo "Error: ImageMagick not found."
  exit 5
}

command -v jq >/dev/null || {
  echo "Error: jq not found."
  exit 6
}

echo "Applying wallpaper and generating colors with matugen..."
matugen image "$IMAGE_PATH" --prefer less-saturation

# --------------------------------------------------
# Tint hyprlock image
# --------------------------------------------------

SOURCE_IMAGE="$HOME/Pictures/wallpapers/moonv1.png"
CACHE_DIR="$HOME/.cache/hyprlock"
OUTPUT_IMAGE="$CACHE_DIR/moon_tinted.png"
WAYBAR_COLORS="$HOME/.config/waybar/colors.css"

mkdir -p "$CACHE_DIR"

[[ -f "$WAYBAR_COLORS" ]] || {
  echo "Error: Waybar colors file not found."
  exit 7
}

# Extract primary color from waybar colors.css
PRIMARY_COLOR=$(grep '@define-color primary' "$WAYBAR_COLORS" \
  | grep -o '#[A-Fa-f0-9]\{6\}')

[[ -n "$PRIMARY_COLOR" ]] || {
  echo "Error: Could not extract primary color."
  exit 8
}

echo "Using primary color: $PRIMARY_COLOR"
echo "Generating tinted hyprlock image..."

magick "$SOURCE_IMAGE" \
  -fill "$PRIMARY_COLOR" \
  -colorize 10% \
  "$OUTPUT_IMAGE"
echo "Done."
echo "Tinted image saved to:"
echo "$OUTPUT_IMAGE"
