#!/usr/bin/env bash

WALLDIR="$HOME/Pictures/wallpapers"

kitty --class wallpaper-picker --title wallpaper-picker sh -c "
selected=\$(yazi '$WALLDIR' --chooser-file=/tmp/wall_choice.$$ >/dev/tty)
"

choice_file="/tmp/wall_choice.$$"

if [ -f "$choice_file" ]; then
    select_wall=$(cat "$choice_file")
    rm "$choice_file"

    [ -n "$select_wall" ] && ~/.local/bin/chwall "$select_wall"
fi
