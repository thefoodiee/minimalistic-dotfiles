#!/usr/bin/env bash

WALLDIR="$HOME/Pictures/wallpapers"
ROFI_THEME="$HOME/.config/rofi/launchers/type-1/style-5.rasi"

choice=$(for img in "$WALLDIR"/*.{jpg,jpeg,png}; do
    [ -e "$img" ] || continue
    basename "$img"
done | rofi \
    -dmenu \
    -i \
    -p "Select wallpaper" \
    -theme "$ROFI_THEME")

[ -z "$choice" ] && exit

select_wall="$WALLDIR/$choice"

/home/urmum/.local/bin/chwall "$select_wall"
