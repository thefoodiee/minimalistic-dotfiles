#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/Pictures/wallpapers"
STATE_FILE="$HOME/.cache/weekly-wallpaper"

# Get current year-week (e.g., 2026-14)
CURRENT_WEEK=$(date +%G-%V)

# Read last run week
if [[ -f "$STATE_FILE" ]]; then
    LAST_WEEK=$(cat "$STATE_FILE")
else
    LAST_WEEK=""
fi

# Exit if already changed this week
if [[ "$CURRENT_WEEK" == "$LAST_WEEK" ]]; then
    exit 0
fi

# Pick a random wallpaper
WALLPAPER=$(find "$WALLPAPER_DIR" -type f \( \
    -iname '*.jpg' -o -iname '*.png' -o -iname '*.jpeg' -o -iname '*.webp' \
\) | shuf -n 1)

# Safety check
[[ -z "$WALLPAPER" ]] && exit 1

# Change wallpaper
/home/urmum/.local/bin/chwall "$WALLPAPER"

# Save current week
echo "$CURRENT_WEEK" > "$STATE_FILE"
