{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock [l]",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprshutdown"
    "text" : "Logout [o]",
    "keybind" : "o"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown --post-cmd 'shutdown -P 0'",
    "text" : "Shutdown [s]",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend [u]",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown --post-cmd 'reboot'",
    "text" : "Reboot [r]",
    "keybind" : "r"
}
{
  "label" : "hibernate",
  "action" : "systemctl hibernate",
  "text" : "Hibernate [h]",
  "keybind" : "h"
}
