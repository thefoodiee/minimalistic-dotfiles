{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprshutdown"
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown --post-cmd 'shutdown -P 0'",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown --post-cmd 'reboot'",
    "text" : "Reboot",
    "keybind" : "r"
}
{
  "label" : "hibernate",
  "action" : "systemctl hibernate",
  "text" : "Hibernate",
  "keybind" : "h"
}
